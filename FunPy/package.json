{
  "name": "funpy",
  "displayName": "FunPy",
  "description": "Fun Python mood booster! Get jokes, tips, and fun feedback as you code.",
  "version": "0.0.1",
  "publisher": "kaushiki-dev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "images/funpy-logo.png",
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "funpy.checkMood",
        "title": "FunPy: Check Python Mood"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "eslint": "^9.32.0",
    "@vscode/test-cli": "^0.0.11"
  }
}